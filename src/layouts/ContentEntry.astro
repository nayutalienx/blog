---
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';
import { tagSlug, withBase } from '../lib/content';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	language?: 'en' | 'ru';
	translations?: Array<{
		language: 'en' | 'ru';
		title: string;
		url: string;
	}>;
	status?: string;
	kind: 'Blog' | 'Note';
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags = [],
	language = 'en',
	translations = [],
	status,
	kind,
} = Astro.props;

const languageNames = {
	en: 'English',
	ru: 'Русский',
};
const translationLabel = language === 'ru' ? 'Доступно также:' : 'Also available:';
---

<BaseLayout
	title={title}
	description={description}
	lang={language}
	ogType="article"
	pubDate={pubDate}
	updatedDate={updatedDate}
	tags={tags}
>
	<article class="post">
		<header class="post-header">
			<h1 class="post-title">{title}</h1>
			<p class="post-meta">
				<FormattedDate date={pubDate} />
				{updatedDate && <span> • Updated <FormattedDate date={updatedDate} /></span>}
				{kind === 'Note' && status && <span> • {status}</span>}
			</p>
			{translations.length > 0 && (
				<nav class="language-switcher" aria-label="Translations">
					<span>{translationLabel}</span>
					{translations.map((translation) => (
						<a href={translation.url} hreflang={translation.language} lang={translation.language}>
							{languageNames[translation.language]}
						</a>
					))}
				</nav>
			)}
			{tags.length > 0 && (
				<ul class="tag-list" aria-label="Tags">
					{tags.map((tag) => (
						<li>
							<a href={withBase(`tags/${tagSlug(tag)}/`)}>{tag}</a>
						</li>
					))}
				</ul>
			)}
		</header>
		<div class="post-content e-content">
			<slot />
		</div>
	</article>
</BaseLayout>
