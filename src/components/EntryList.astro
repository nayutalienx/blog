---
import FormattedDate from './FormattedDate.astro';
import { entryKind, entryUrl, tagSlug, withBase, type Entry } from '../lib/content';

interface Props {
	entries: Entry[];
	emptyText?: string;
	showCollection?: boolean;
	showDescription?: boolean;
	showTags?: boolean;
}

const {
	entries,
	emptyText = 'Nothing published yet.',
	showCollection = false,
	showDescription = false,
	showTags = false,
} = Astro.props;
---

{
	entries.length > 0 ? (
		<ul class="post-list">
			{entries.map((entry) => (
				<li>
					<p class="post-meta">
						{showCollection && <span>{entryKind(entry)} - </span>}
						<FormattedDate date={entry.data.pubDate} />
						{entry.collection === 'notes' && entry.data.status && <span> - {entry.data.status}</span>}
					</p>
					<h3>
						<a class="post-link" href={entryUrl(entry)}>
							{entry.data.title}
						</a>
					</h3>
					{showDescription && <p>{entry.data.description}</p>}
					{showTags && entry.data.tags.length > 0 && (
						<ul class="tag-list" aria-label="Tags">
							{entry.data.tags.map((tag) => (
								<li>
									<a href={withBase(`tags/${tagSlug(tag)}/`)}>{tag}</a>
								</li>
							))}
						</ul>
					)}
				</li>
			))}
		</ul>
	) : (
		<p>{emptyText}</p>
	)
}
