---
import { REPO_URL, SITE_EMAIL, SITE_X_LABEL, SITE_X_URL } from '../consts';
---

<footer class="site-footer">
	<div class="wrapper">
		<div class="footer-col-wrapper">
			<div class="footer-col footer-col-1">
				<ul class="contact-list">
					<li><a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a></li>
				</ul>
			</div>

			<div class="footer-col footer-col-2">
				<ul class="social-media-list">
					<li><a href={REPO_URL} target="_blank" rel="noreferrer">GitHub</a></li>
					<li><a href={SITE_X_URL} target="_blank" rel="noreferrer">{SITE_X_LABEL}</a></li>
				</ul>
			</div>
		</div>
	</div>
</footer>
